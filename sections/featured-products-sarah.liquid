<!-- ============================================================
   FEATURED PRODUCTS — Best-sellers de l'été
   ============================================================ -->
<section class="sr-products-section">
  <span class="sr-section-script">{{ section.settings.script | default: "best-sellers" }}</span>
  <h2 class="sr-section-h2">{{ section.settings.heading | default: "Les indispensables de l'été" }}</h2>
  <p class="sr-section-desc">{{ section.settings.description | default: "Nos pièces les plus aimées pour une saison lumineuse." }}</p>

  <div class="sr-products-grid">
    {%- if section.settings.collection != blank -%}
      {%- for product in collections[section.settings.collection].products limit: section.settings.products_count -%}
        {%- render 'product-card-sarah', product: product -%}
      {%- else -%}
        {%- render 'product-card-sarah--placeholder' -%}
      {%- endfor -%}
    {%- else -%}
      <!-- Fallback: 3 placeholders pour l'éditeur de thème -->
      {%- for i in (1..3) -%}
        <article class="sr-card">
          <div class="sr-card__media">
            <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,#F2DCD6,#F2DCD6 14px,#F8E7E2 14px,#F8E7E2 28px);display:flex;align-items:center;justify-content:center;color:rgba(58,51,48,.4);font-size:11px;letter-spacing:.1em;text-transform:uppercase">photo produit</div>
          </div>
          <div class="sr-card__footer">
            <span class="sr-card__title">Produit {{ i }}</span>
            <span class="sr-card__price">– €</span>
          </div>
          <button class="sr-card__atc">Ajouter au panier</button>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.cta_url != blank -%}
    <div style="text-align:center;margin-top:42px">
      <a href="{{ section.settings.cta_url }}" class="sr-btn sr-btn--ghost">
        {{ section.settings.cta_label | default: "Voir tous les produits" }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Produits vedettes",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "script",
      "label": "Label cursive",
      "default": "best-sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Les indispensables de l'été"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Nos pièces les plus aimées pour une saison lumineuse."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection à afficher"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Nombre de produits",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Bouton – texte",
      "default": "Voir tous les produits"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Bouton – lien"
    }
  ],
  "presets": [
    {
      "name": "Produits vedettes"
    }
  ]
}
{% endschema %}
