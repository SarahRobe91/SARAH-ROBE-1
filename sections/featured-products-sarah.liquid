<section class="sr-products-section">
  <span class="sr-section-script">{{ section.settings.script | default: "best-sellers" }}</span>
  <h2 class="sr-section-h2">{{ section.settings.heading | default: "Les indispensables de l'été" }}</h2>
  <p class="sr-section-desc">{{ section.settings.description | default: "Nos pièces les plus aimées pour une saison lumineuse." }}</p>

  <div class="sr-products-grid">
    {%- assign featured_collection = section.settings.collection -%}

    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      {%- for product in featured_collection.products limit: section.settings.products_count -%}
        {%- render 'product-card-sarah', product: product -%}
      {%- endfor -%}

    {%- elsif featured_collection != blank -%}
      {%- if request.design_mode -%}
        <p style="grid-column:1/-1;text-align:center;padding:40px 20px;color:#9a8f86;font-size:13px;letter-spacing:.04em">
          Cette collection ne contient aucun produit.
        </p>
      {%- endif -%}

    {%- else -%}
      {%- if request.design_mode -%}
        <p style="grid-column:1/-1;text-align:center;padding:40px 20px;color:#9a8f86;font-size:13px;letter-spacing:.04em">
          Sélectionne une collection dans le panneau de droite pour afficher les produits.
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- if section.settings.cta_url != blank -%}
    <div style="text-align:center;margin-top:42px">
      <a href="{{ section.settings.cta_url }}" class="sr-btn sr-btn--ghost">
        {{ section.settings.cta_label | default: "Voir tous les produits" }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Produits vedettes",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "script",
      "label": "Label cursive",
      "default": "best-sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Les indispensables de l'été"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Nos pièces les plus aimées pour une saison lumineuse."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection à afficher"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Nombre de produits",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Bouton – texte",
      "default": "Voir tous les produits"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Bouton – lien"
    }
  ],
  "presets": [
    {
      "name": "Produits vedettes"
    }
  ]
}
{% endschema %}
