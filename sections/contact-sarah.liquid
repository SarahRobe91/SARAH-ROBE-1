<!-- ============================================================
   CONTACT — Section avec formulaire Shopify natif
   ============================================================ -->
<section id="contact" class="sr-contact">
  <!-- Wave top -->
  <svg class="sr-wave-top" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,34 C250,94 520,86 760,52 C1010,18 1230,16 1440,42 L1440,0 L0,0 Z" fill="#FBF3EC"/>
  </svg>

  <div class="sr-contact__header">
    <span class="sr-contact__script">{{ section.settings.script | default: "une question ?" }}</span>
    <h2 class="sr-contact__h2">{{ section.settings.heading | default: "Contactez Sarah Robe" }}</h2>
    <p class="sr-contact__intro">{{ section.settings.intro | default: "Besoin d'un conseil sur une robe, un parfum ou une commande ? Écrivez-nous, notre équipe vous répond avec plaisir." }}</p>
  </div>

  <div class="sr-contact__grid">

    <!-- Bloc informations -->
    <div class="sr-contact__info">
      <h3 class="sr-contact__info-title">Service client</h3>
      <p class="sr-contact__info-sub">Nous vous accompagnons avant et après votre commande.</p>

      {%- if section.settings.phone != blank -%}
        <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="sr-contact__info-item">
          <span class="sr-contact__info-icon sr-contact__info-icon--blue">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#5f7d8c" stroke-width="1.5"><path d="M5 4h3l1.6 4-2 1.4a11 11 0 005 5l1.4-2 4 1.6v3a2 2 0 01-2.2 2A16 16 0 013 6.2 2 2 0 015 4z"/></svg>
          </span>
          <span>
            <span class="sr-contact__info-label">Téléphone</span>
            <span class="sr-contact__info-value">{{ section.settings.phone }}</span>
          </span>
        </a>
      {%- endif -%}

      {%- if section.settings.email != blank -%}
        <a href="mailto:{{ section.settings.email }}" class="sr-contact__info-item">
          <span class="sr-contact__info-icon sr-contact__info-icon--rose">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#B07A6B" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="M3 7l9 6 9-6"/></svg>
          </span>
          <span>
            <span class="sr-contact__info-label">Email</span>
            <span class="sr-contact__info-value">{{ section.settings.email }}</span>
          </span>
        </a>
      {%- endif -%}

      <div class="sr-contact__info-item">
        <span class="sr-contact__info-icon sr-contact__info-icon--green">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#4f6258" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        </span>
        <span>
          <span class="sr-contact__info-label">Disponibilité</span>
          <span class="sr-contact__info-value">{{ section.settings.availability | default: "Réponse sous 24h à 48h" }}</span>
        </span>
      </div>

      <div class="sr-contact__divider"></div>

      <div class="sr-contact__checks">
        <div class="sr-contact__check">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C28B7C" stroke-width="2"><path d="M5 12l5 5L20 6"/></svg>
          Livraison &amp; retours
        </div>
        <div class="sr-contact__check">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C28B7C" stroke-width="2"><path d="M5 12l5 5L20 6"/></svg>
          Conseils taille et parfums
        </div>
        <div class="sr-contact__check">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C28B7C" stroke-width="2"><path d="M5 12l5 5L20 6"/></svg>
          Suivi de commande
        </div>
      </div>

      <!-- Réseaux sociaux -->
      <div style="margin-top:26px">
        <div class="sr-contact__socials-label">Ou contactez-nous aussi sur</div>
        <div class="sr-contact__socials-grid">
          {%- if section.settings.whatsapp_url != blank -%}
            <a href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'whatsapp.png' | asset_url }}" alt="WhatsApp" loading="lazy">
              </span>
              <span class="sr-contact__social-name">WhatsApp</span>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'instagram.png' | asset_url }}" alt="Instagram" loading="lazy">
              </span>
              <span class="sr-contact__social-name">Instagram</span>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'tiktok.png' | asset_url }}" alt="TikTok" loading="lazy">
              </span>
              <span class="sr-contact__social-name">TikTok</span>
            </a>
          {%- endif -%}
          {%- if section.settings.snapchat_url != blank -%}
            <a href="{{ section.settings.snapchat_url }}" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'snapchat.png' | asset_url }}" alt="Snapchat" loading="lazy">
              </span>
              <span class="sr-contact__social-name">Snapchat</span>
            </a>
          {%- endif -%}
          {%- if section.settings.whatsapp_url == blank and section.settings.instagram_url == blank -%}
            <!-- Fallback avec logos uploadés -->
            <a href="https://wa.me/33600000000" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'whatsapp.png' | asset_url }}" alt="WhatsApp" loading="lazy">
              </span>
              <span class="sr-contact__social-name">WhatsApp</span>
            </a>
            <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'instagram.png' | asset_url }}" alt="Instagram" loading="lazy">
              </span>
              <span class="sr-contact__social-name">Instagram</span>
            </a>
            <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'tiktok.png' | asset_url }}" alt="TikTok" loading="lazy">
              </span>
              <span class="sr-contact__social-name">TikTok</span>
            </a>
            <a href="https://snapchat.com" target="_blank" rel="noopener noreferrer" class="sr-contact__social-link">
              <span class="sr-contact__social-icon">
                <img src="{{ 'snapchat.png' | asset_url }}" alt="Snapchat" loading="lazy">
              </span>
              <span class="sr-contact__social-name">Snapchat</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Formulaire contact Shopify natif -->
    <div class="sr-contact__form-wrap">
      {%- form 'contact', id: 'sr-contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="sr-contact__success">
            Merci ! Votre message a bien été envoyé — nous vous répondons sous 24h à 48h.
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="sr-contact__success" style="background:#FDEAEA;border-color:#E4C0C0;color:#6f3030">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="sr-contact__fields">
          <label class="sr-field">
            <span class="sr-field__label">Nom</span>
            <input type="text" name="contact[name]" class="sr-field__input"
                   placeholder="Votre nom"
                   value="{{ form.name }}" required>
          </label>

          <label class="sr-field">
            <span class="sr-field__label">Email</span>
            <input type="email" name="contact[email]" class="sr-field__input"
                   placeholder="vous@email.com"
                   value="{{ form.email }}" required>
          </label>

          <label class="sr-field">
            <span class="sr-field__label">Sujet</span>
            <input type="text" name="contact[subject]" class="sr-field__input"
                   placeholder="L'objet de votre message">
          </label>

          <label class="sr-field">
            <span class="sr-field__label">Message</span>
            <textarea name="contact[body]" class="sr-field__textarea"
                      rows="4"
                      placeholder="Votre message…"
                      required>{{ form.body }}</textarea>
          </label>

          <button type="submit" class="sr-btn sr-btn--primary sr-btn--full" style="margin-top:6px">
            Envoyer le message
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "script",
      "label": "Label cursive",
      "default": "une question ?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Contactez Sarah Robe"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Téléphone",
      "default": "06 00 00 00 00"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "contact@sarahrobe.fr"
    },
    {
      "type": "text",
      "id": "availability",
      "label": "Disponibilité",
      "default": "Réponse sous 24h à 48h"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "snapchat_url",
      "label": "Snapchat URL"
    }
  ],
  "presets": [
    {
      "name": "Contact"
    }
  ]
}
{% endschema %}
