{% comment %} SARAH ROBE — Page Panier Premium {% endcomment %}

{%- assign threshold_str = settings.free_shipping_threshold | default: "69" -%}
{%- assign threshold_cents = threshold_str | times: 100 -%}

<!-- Hero panier -->
<div class="sr-collection-hero">
  <div class="sr-collection-hero__texture"></div>
  <div class="sr-collection-hero__deco1"></div>
  <div class="sr-collection-hero__deco2"></div>
  <div class="sr-collection-hero__content">
    <nav class="sr-breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a>
      <span class="sr-breadcrumb__sep">/</span>
      <span style="color:#3A3330">Mon Panier</span>
    </nav>
    <span class="sr-collection-hero__script">{{ section.settings.hero_script | default: "ma sélection" }}</span>
    <h1 class="sr-collection-hero__h1">{{ section.settings.hero_heading | default: "Votre sélection d'été" }}</h1>
    {%- unless cart.empty? -%}
      <p class="sr-collection-hero__desc">
        {{ cart.item_count }} article{%- if cart.item_count > 1 -%}s{%- endif -%} — {{ cart.total_price | money }}
      </p>
    {%- endunless -%}
  </div>
  <svg style="position:absolute;bottom:-1px;left:0;width:100%;height:74px;display:block" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,52 C300,108 620,4 920,40 C1140,67 1300,78 1440,44 L1440,90 L0,90 Z" fill="#FBF7F1"/>
  </svg>
</div>

{%- if cart.empty? -%}

  <!-- Panier vide -->
  <div class="sr-cart-empty">
    <span class="sr-cart-empty__script">oups</span>
    <h2 class="sr-cart-empty__h2">Votre panier est vide</h2>
    <p class="sr-cart-empty__desc">Explorez nos collections et laissez-vous inspirer par les pièces de la saison.</p>
    <a href="/collections" class="sr-btn sr-btn--primary" style="margin-top:24px">
      Découvrir les collections
    </a>
  </div>

{%- else -%}

  <div class="sr-cart-page">

    <!-- Colonne articles -->
    <div class="sr-cart-items-col">
      {%- form 'cart', cart, id: 'sr-cart-form-page' -%}
        <div class="sr-cart-items-list" id="sr-cart-items-page">
          {%- for item in cart.items -%}
            <div class="sr-cart-item" data-sr-item="{{ item.key }}">

              <a href="{{ item.url }}" class="sr-cart-item__img-wrap" tabindex="-1">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 240 }}"
                       alt="{{ item.image.alt | escape | default: item.product.title }}"
                       class="sr-cart-item__img"
                       loading="lazy"
                       width="120" height="160">
                {%- endif -%}
              </a>

              <div class="sr-cart-item__body">
                <div class="sr-cart-item__top">
                  <div style="min-width:0">
                    <a href="{{ item.url }}" class="sr-cart-item__title">{{ item.product.title }}</a>
                    {%- unless item.product.has_only_default_variant -%}
                      <p class="sr-cart-item__variant">{{ item.variant.title }}</p>
                    {%- endunless -%}
                    {%- if item.selling_plan_allocation -%}
                      <p class="sr-cart-item__variant">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                    {%- endif -%}
                  </div>
                  <button class="sr-cart-item__remove"
                          type="button"
                          aria-label="Retirer {{ item.product.title }}"
                          data-sr-page-remove="{{ item.key }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                      <path d="M18 6L6 18M6 6l12 12"/>
                    </svg>
                  </button>
                </div>

                <div class="sr-cart-item__bottom">
                  <div class="sr-cart-item__qty-ctrl" role="group" aria-label="Quantité">
                    <button type="button"
                            class="sr-cart-item__qty-btn"
                            aria-label="Diminuer"
                            data-sr-page-qty="{{ item.key }}"
                            data-action="minus">−</button>
                    <input type="number"
                           name="updates[{{ item.key }}]"
                           value="{{ item.quantity }}"
                           min="0"
                           class="sr-cart-item__qty-input"
                           aria-label="Quantité"
                           data-sr-page-qty-input="{{ item.key }}">
                    <button type="button"
                            class="sr-cart-item__qty-btn"
                            aria-label="Augmenter"
                            data-sr-page-qty="{{ item.key }}"
                            data-action="plus">+</button>
                  </div>
                  <div class="sr-cart-item__price-wrap">
                    {%- if item.original_price != item.final_price -%}
                      <span class="sr-cart-item__price--old">{{ item.original_price | times: item.quantity | money }}</span>
                    {%- endif -%}
                    <span class="sr-cart-item__price">{{ item.final_price | times: item.quantity | money }}</span>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- Note éditoriale -->
        <div class="sr-cart-editorial">
          <span class="sr-cart-editorial__icon" aria-hidden="true">✦</span>
          <p>{{ section.settings.editorial_text | default: "Une sélection pensée pour vos journées ensoleillées — des pièces légères, des matières douces, un style qui traverse la saison." }}</p>
        </div>
      {%- endform -%}
    </div>

    <!-- Résumé commande -->
    <aside class="sr-cart-summary" aria-label="Résumé de la commande">
      <div class="sr-cart-summary__inner">
        <h2 class="sr-cart-summary__title">Résumé</h2>

        {%- assign cart_total_cents = cart.total_price -%}
        {%- if cart_total_cents >= threshold_cents -%}
          <div class="sr-cart-shipping-banner sr-cart-shipping-banner--free">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Livraison offerte !
          </div>
        {%- else -%}
          {%- assign remaining_cents = threshold_cents | minus: cart_total_cents -%}
          <div class="sr-cart-shipping-banner">
            Plus que <strong>{{ remaining_cents | money }}</strong> pour la livraison offerte
          </div>
        {%- endif -%}

        <div class="sr-cart-summary__lines">
          <div class="sr-cart-summary__line">
            <span>Sous-total ({{ cart.item_count }} art.)</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div class="sr-cart-summary__line sr-cart-summary__line--muted">
            <span>Livraison</span>
            <span>Calculée à l'étape suivante</span>
          </div>
        </div>

        <div class="sr-cart-summary__total">
          <span>Total estimé</span>
          <span>{{ cart.total_price | money }}</span>
        </div>

        <a href="/checkout" class="sr-btn sr-btn--primary sr-btn--full sr-cart-summary__cta">
          Passer au paiement →
        </a>

        <p class="sr-cart-summary__secure">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0110 0v4"/>
          </svg>
          Paiement 100 % sécurisé
        </p>

        <ul class="sr-cart-reassurance">
          <li class="sr-cart-reassurance__item">
            <span class="sr-cart-reassurance__icon" aria-hidden="true">🌿</span>
            <span>{{ section.settings.reassurance_1 | default: "Livraison soignée & emballage premium" }}</span>
          </li>
          <li class="sr-cart-reassurance__item">
            <span class="sr-cart-reassurance__icon" aria-hidden="true">↩</span>
            <span>{{ section.settings.reassurance_2 | default: "Retours acceptés sous 14 jours" }}</span>
          </li>
          <li class="sr-cart-reassurance__item">
            <span class="sr-cart-reassurance__icon" aria-hidden="true">💌</span>
            <span>{{ section.settings.reassurance_3 | default: "Service client disponible pour vous" }}</span>
          </li>
        </ul>
      </div>
    </aside>
  </div>

{%- endif -%}

<script>
(function() {
  const form = document.getElementById('sr-cart-form-page');
  if (!form) return;

  function reloadCart() { window.location.reload(); }

  async function changeLineByKey(key, qty) {
    try {
      const body = JSON.stringify({ id: key, quantity: qty });
      const resp = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body
      });
      if (resp.ok) reloadCart();
    } catch(e) { reloadCart(); }
  }

  // Remove buttons
  document.querySelectorAll('[data-sr-page-remove]').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.srPageRemove;
      changeLineByKey(key, 0);
    });
  });

  // Qty +/- buttons
  document.querySelectorAll('[data-sr-page-qty]').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.srPageQty;
      const action = btn.dataset.action;
      const input = document.querySelector('[data-sr-page-qty-input="' + key + '"]');
      if (!input) return;
      let val = parseInt(input.value, 10) || 0;
      if (action === 'minus') val = Math.max(0, val - 1);
      if (action === 'plus') val = val + 1;
      input.value = val;
      changeLineByKey(key, val);
    });
  });
})();
</script>

{% schema %}
{
  "name": "Page Panier",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "hero_script",   "label": "Label cursive hero",  "default": "ma sélection" },
    { "type": "text",     "id": "hero_heading",  "label": "Titre hero",          "default": "Votre sélection d'été" },
    { "type": "textarea", "id": "editorial_text","label": "Note éditoriale (bas de panier)", "default": "Une sélection pensée pour vos journées ensoleillées — des pièces légères, des matières douces, un style qui traverse la saison." },
    { "type": "text",     "id": "reassurance_1", "label": "Réassurance 1",       "default": "Livraison soignée & emballage premium" },
    { "type": "text",     "id": "reassurance_2", "label": "Réassurance 2",       "default": "Retours acceptés sous 14 jours" },
    { "type": "text",     "id": "reassurance_3", "label": "Réassurance 3",       "default": "Service client disponible pour vous" }
  ]
}
{% endschema %}
