<!-- ============================================================
   HERO — Page d'accueil
   ============================================================ -->
<section class="sr-hero">
  <div class="sr-hero__texture"></div>

  {%- assign desktop_img = section.settings.hero_image -%}
  {%- assign mobile_img  = section.settings.hero_image_mobile -%}

  {%- if desktop_img != blank or mobile_img != blank -%}
    {%- assign main_img = desktop_img | default: mobile_img -%}
    <picture>
      {%- if mobile_img != blank -%}
        <source media="(max-width: 749px)"
                srcset="{{ mobile_img | image_url: width: 900 }}">
      {%- endif -%}
      <img src="{{ main_img | image_url: width: 2200 }}"
           alt="{{ main_img.alt | escape | default: section.settings.heading | escape }}"
           class="sr-hero__img"
           width="{{ main_img.width }}"
           height="{{ main_img.height }}"
           loading="eager"
           fetchpriority="high">
    </picture>
  {%- else -%}
    <span class="sr-hero__img-placeholder">[ photo lifestyle · plage soleil robe légère ]</span>
  {%- endif -%}

  <div class="sr-hero__content">
    <span class="sr-hero__script">{{ section.settings.script_label | default: "summer" }}</span>
    <h1 class="sr-hero__h1">
      {{ section.settings.heading | default: "L'été commence avec" }}<br>
      <em>{{ section.settings.brand_em | default: "Sarah Robe" }}</em>
    </h1>
    <p class="sr-hero__desc">
      {{ section.settings.description | default: "Robes légères, tenues solaires et parfums d'été pour sublimer chaque moment." }}
    </p>
    <div class="sr-hero__ctas">
      <a href="{{ section.settings.cta1_url | default: '/collections' }}" class="sr-btn sr-btn--primary">
        {{ section.settings.cta1_label | default: "Nos collections" }}
      </a>
      <a href="{{ section.settings.cta2_url | default: '/collections/all' }}" class="sr-btn sr-btn--outline">
        {{ section.settings.cta2_label | default: "Tous nos produits" }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image hero PC (paysage)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Image hero téléphone (portrait)"
    },
    {
      "type": "text",
      "id": "script_label",
      "label": "Label script (cursive)",
      "default": "summer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre principal",
      "default": "L'été commence avec"
    },
    {
      "type": "text",
      "id": "brand_em",
      "label": "Nom en italique",
      "default": "Sarah Robe"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Robes légères, tenues solaires et parfums d'été pour sublimer chaque moment."
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Bouton 1 – texte",
      "default": "Nos collections"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "Bouton 1 – lien"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Bouton 2 – texte",
      "default": "Tous nos produits"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Bouton 2 – lien"
    }
  ],
  "presets": [
    {
      "name": "Hero Sarah Robe"
    }
  ]
}
{% endschema %}
