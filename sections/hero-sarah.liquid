<!-- ============================================================
   HERO — Page d'accueil
   ============================================================ -->
<section class="sr-hero">
  <div class="sr-hero__texture"></div>

  {%- if section.settings.hero_image != blank -%}
    <img src="{{ section.settings.hero_image | image_url: width: 1920 }}"
         alt="{{ section.settings.hero_image.alt | escape }}"
         class="sr-hero__img"
         width="{{ section.settings.hero_image.width }}"
         height="{{ section.settings.hero_image.height }}"
         loading="eager">
  {%- else -%}
    <span class="sr-hero__img-placeholder">[ photo lifestyle · plage soleil robe légère ]</span>
  {%- endif -%}

  <div class="sr-hero__content">
    <span class="sr-hero__script">{{ section.settings.script_label | default: "summer" }}</span>
    <h1 class="sr-hero__h1">
      {{ section.settings.heading | default: "L'été commence avec" }}<br>
      <em>{{ section.settings.brand_em | default: "Sarah Robe" }}</em>
    </h1>
    <p class="sr-hero__desc">
      {{ section.settings.description | default: "Robes légères, tenues solaires et parfums d'été pour sublimer chaque moment." }}
    </p>
    <div class="sr-hero__ctas">
      <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="sr-btn sr-btn--primary">
        {{ section.settings.cta1_label | default: "Découvrir la collection" }}
      </a>
      <a href="{{ section.settings.cta2_url | default: '/collections/parfums' }}" class="sr-btn sr-btn--outline">
        {{ section.settings.cta2_label | default: "Voir les parfums" }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image hero (lifestyle)"
    },
    {
      "type": "text",
      "id": "script_label",
      "label": "Label script (cursive)",
      "default": "summer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre principal",
      "default": "L'été commence avec"
    },
    {
      "type": "text",
      "id": "brand_em",
      "label": "Nom en italique",
      "default": "Sarah Robe"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Robes légères, tenues solaires et parfums d'été pour sublimer chaque moment."
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Bouton 1 – texte",
      "default": "Découvrir la collection"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "Bouton 1 – lien"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Bouton 2 – texte",
      "default": "Voir les parfums"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Bouton 2 – lien"
    }
  ],
  "presets": [
    {
      "name": "Hero Sarah Robe"
    }
  ]
}
{% endschema %}
