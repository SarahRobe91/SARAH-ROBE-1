<!-- ============================================================
   CATEGORIES — Nos univers d'été
   ============================================================ -->
<section class="sr-categories">
  <div class="sr-categories__header">
    <span class="sr-section-script">{{ section.settings.script | default: "explorez" }}</span>
    <h2 class="sr-section-h2" style="margin-bottom:0">{{ section.settings.heading | default: "Nos univers d'été" }}</h2>
  </div>

  <div class="sr-categories__grid">
    {%- for block in section.blocks -%}

      {%- comment -%} Résolution URL {%- endcomment -%}
      {%- assign _coll = block.settings.collection -%}
      {%- if _coll != blank -%}
        {%- assign _url = _coll.url -%}
      {%- elsif block.settings.url != blank -%}
        {%- assign _url = block.settings.url -%}
      {%- else -%}
        {%- assign _url = '/collections/all' -%}
      {%- endif -%}

      {%- comment -%} Résolution titre {%- endcomment -%}
      {%- if block.settings.title != blank -%}
        {%- assign _title = block.settings.title -%}
      {%- elsif block.settings.name != blank -%}
        {%- assign _title = block.settings.name -%}
      {%- elsif _coll != blank -%}
        {%- assign _title = _coll.title -%}
      {%- else -%}
        {%- assign _title = 'Catégorie' -%}
      {%- endif -%}

      {%- comment -%} Résolution image {%- endcomment -%}
      {%- if block.settings.image != blank -%}
        {%- assign _img = block.settings.image -%}
      {%- elsif _coll != blank and _coll.image != blank -%}
        {%- assign _img = _coll.image -%}
      {%- else -%}
        {%- assign _img = blank -%}
      {%- endif -%}

      <a href="{{ _url }}"
         class="sr-category-item"
         {{ block.shopify_attributes }}>
        <div class="sr-category-item__circle sr-category-item__circle--{{ block.settings.color | default: 'rose' }}">
          {%- if _img != blank -%}
            <img src="{{ _img | image_url: width: 430 }}"
                 alt="{{ _title | escape }}"
                 style="width:100%;height:100%;object-fit:cover;border-radius:50%"
                 loading="lazy">
          {%- endif -%}
        </div>
        <span class="sr-category-item__name">{{ _title }}</span>
        {%- if block.settings.subtitle != blank -%}
          <span class="sr-category-item__subtitle">{{ block.settings.subtitle }}</span>
        {%- endif -%}
        <span class="sr-category-item__link">Voir la sélection →</span>
      </a>

    {%- else -%}
      {%- comment -%}
        Aucun bloc défini : on affiche un message uniquement dans l'éditeur.
        Ne jamais afficher de cartes hardcodées ici — elles seraient non-éditables.
      {%- endcomment -%}
      {%- if request.design_mode -%}
        <p style="grid-column:1/-1;text-align:center;padding:40px 20px;color:#9a8f86;font-size:13px;letter-spacing:.05em">
          Cliquez sur « Ajouter un bloc » dans le panneau de gauche pour ajouter des catégories.
        </p>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
.sr-category-item__subtitle {
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--sr-muted);
  display: block;
}
</style>

{% schema %}
{
  "name": "Catégories été",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "script",
      "label": "Label cursive",
      "default": "explorez"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nos univers d'été"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection Shopify"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre personnalisé (remplace le nom de la collection)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Sous-titre / label optionnel"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image personnalisée (remplace l'image de la collection)"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Couleur de fond du cercle",
          "options": [
            { "value": "rose",  "label": "Rose poudré" },
            { "value": "bleu",  "label": "Bleu pastel" },
            { "value": "dore",  "label": "Beige doré" },
            { "value": "vert",  "label": "Vert doux" }
          ],
          "default": "rose"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Lien manuel (si aucune collection sélectionnée)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom (champ hérité — préférer Titre)"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Catégories été",
      "blocks": [
        { "type": "category", "settings": { "title": "Robes d'été",          "color": "rose" } },
        { "type": "category", "settings": { "title": "Ensembles légers",     "color": "bleu" } },
        { "type": "category", "settings": { "title": "Accessoires solaires", "color": "dore" } },
        { "type": "category", "settings": { "title": "Parfums",              "color": "vert" } }
      ]
    }
  ]
}
{% endschema %}
