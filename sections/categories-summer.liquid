<!-- ============================================================
   CATEGORIES — Nos univers d'été
   ============================================================ -->
<section class="sr-categories">
  <div class="sr-categories__header">
    <span class="sr-section-script">{{ section.settings.script | default: "explorez" }}</span>
    <h2 class="sr-section-h2" style="margin-bottom:0">{{ section.settings.heading | default: "Nos univers d'été" }}</h2>
  </div>

  <div class="sr-categories__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.url | default: '/collections/all' }}"
         class="sr-category-item"
         {{ block.shopify_attributes }}>
        <div class="sr-category-item__circle sr-category-item__circle--{{ block.settings.color | default: 'rose' }}">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 430 }}"
                 alt="{{ block.settings.name }}"
                 style="width:100%;height:100%;object-fit:cover;border-radius:50%"
                 loading="lazy">
          {%- endif -%}
        </div>
        <span class="sr-category-item__name">{{ block.settings.name }}</span>
        <span class="sr-category-item__link">Voir la sélection →</span>
      </a>
    {%- else -%}
      <a href="/collections/robes" class="sr-category-item">
        <div class="sr-category-item__circle sr-category-item__circle--rose"></div>
        <span class="sr-category-item__name">Robes d'été</span>
        <span class="sr-category-item__link">Voir la sélection →</span>
      </a>
      <a href="/collections/ensembles" class="sr-category-item">
        <div class="sr-category-item__circle sr-category-item__circle--bleu"></div>
        <span class="sr-category-item__name">Ensembles légers</span>
        <span class="sr-category-item__link">Voir la sélection →</span>
      </a>
      <a href="/collections/accessoires" class="sr-category-item">
        <div class="sr-category-item__circle sr-category-item__circle--dore"></div>
        <span class="sr-category-item__name">Accessoires solaires</span>
        <span class="sr-category-item__link">Voir la sélection →</span>
      </a>
      <a href="/collections/parfums" class="sr-category-item">
        <div class="sr-category-item__circle sr-category-item__circle--vert"></div>
        <span class="sr-category-item__name">Parfums</span>
        <span class="sr-category-item__link">Voir la sélection →</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Catégories été",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "script",
      "label": "Label cursive",
      "default": "explorez"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nos univers d'été"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nom",
          "default": "Robes d'été"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Lien"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Couleur de fond",
          "options": [
            { "value": "rose",  "label": "Rose poudré" },
            { "value": "bleu",  "label": "Bleu pastel" },
            { "value": "dore",  "label": "Beige doré" },
            { "value": "vert",  "label": "Vert doux" }
          ],
          "default": "rose"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Catégories été",
      "blocks": [
        { "type": "category", "settings": { "name": "Robes d'été",        "color": "rose" } },
        { "type": "category", "settings": { "name": "Ensembles légers",   "color": "bleu" } },
        { "type": "category", "settings": { "name": "Accessoires solaires","color": "dore" } },
        { "type": "category", "settings": { "name": "Parfums",            "color": "vert" } }
      ]
    }
  ]
}
{% endschema %}
