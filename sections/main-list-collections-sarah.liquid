<div class="sr-collection-hero">
  <div class="sr-collection-hero__texture"></div>
  <div class="sr-collection-hero__deco1"></div>
  <div class="sr-collection-hero__deco2"></div>

  <div class="sr-collection-hero__content">
    <nav class="sr-breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a>
      <span class="sr-breadcrumb__sep">/</span>
      <span style="color:#3A3330">Collections</span>
    </nav>
    <span class="sr-collection-hero__script">{{ section.settings.script | default: "explorez" }}</span>
    <h1 class="sr-collection-hero__h1">{{ section.settings.heading | default: "Toutes nos collections" }}</h1>
    <p class="sr-collection-hero__desc">{{ section.settings.description | default: "Explorez les univers Sarah Robe : robes d'été, ensembles légers, accessoires solaires et parfums lumineux." }}</p>
  </div>

  <svg style="position:absolute;bottom:-1px;left:0;width:100%;height:74px;display:block" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,52 C300,108 620,4 920,40 C1140,67 1300,78 1440,44 L1440,90 L0,90 Z" fill="#FBF7F1"/>
  </svg>
</div>

<div class="sr-lc-section">
  {%- liquid
    assign _hide_empty  = section.settings.hide_empty
    assign _show_count  = section.settings.show_count
    assign _max         = section.settings.max_collections | default: 12
    assign _btn         = section.settings.btn_text | default: "Voir la sélection →"
    assign _colors      = "rose,bleu,dore,vert" | split: ","
    assign _coll_idx    = 0
    assign _has_any     = false
  -%}

  <div class="sr-categories__grid sr-lc-grid">
    {%- for collection in collections -%}
      {%- if collection.handle == 'frontpage' or collection.handle == 'all' -%}
        {%- continue -%}
      {%- endif -%}
      {%- if _hide_empty and collection.products_count == 0 -%}
        {%- continue -%}
      {%- endif -%}
      {%- if _coll_idx >= _max -%}
        {%- break -%}
      {%- endif -%}

      {%- assign _has_any = true -%}
      {%- assign _color_pos = _coll_idx | modulo: 4 -%}
      {%- assign _circ_color = _colors[_color_pos] -%}

      {%- assign _img = collection.image -%}
      {%- if _img == blank and collection.products.first != blank -%}
        {%- assign _img = collection.products.first.featured_image -%}
      {%- endif -%}

      <a href="{{ collection.url }}" class="sr-category-item">
        <div class="sr-category-item__circle sr-category-item__circle--{{ _circ_color }}">
          {%- if _img != blank -%}
            <img src="{{ _img | image_url: width: 430 }}"
                 alt="{{ collection.title | escape }}"
                 style="width:100%;height:100%;object-fit:cover;border-radius:50%"
                 loading="lazy">
          {%- endif -%}
        </div>
        <span class="sr-category-item__name">{{ collection.title }}</span>
        {%- if _show_count -%}
          <span class="sr-lc-count">
            {{ collection.products_count }} pièce{%- if collection.products_count != 1 -%}s{%- endif -%}
          </span>
        {%- endif -%}
        <span class="sr-category-item__link">{{ _btn }}</span>
      </a>

      {%- assign _coll_idx = _coll_idx | plus: 1 -%}
    {%- endfor -%}

    {%- unless _has_any -%}
      {%- if request.design_mode -%}
        <p style="grid-column:1/-1;text-align:center;padding:40px 20px;color:#9a8f86;font-size:13px;letter-spacing:.04em">
          Aucune collection disponible à afficher.
        </p>
      {%- endif -%}
    {%- endunless -%}
  </div>
</div>

<style>
.sr-lc-section {
  padding: 80px 80px 100px;
}
.sr-lc-count {
  font-size: 12px;
  letter-spacing: .1em;
  color: var(--sr-muted);
  text-transform: uppercase;
  display: block;
}
@media (max-width: 768px) {
  .sr-lc-section { padding: 40px 24px 60px; }
  .sr-lc-grid { grid-template-columns: 1fr 1fr !important; gap: 24px !important; }
  .sr-lc-grid .sr-category-item__circle { width: 140px; height: 140px; }
}
</style>

{% schema %}
{
  "name": "Liste des collections",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "script",
      "label": "Label cursive (hero)",
      "default": "explorez"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre (hero)",
      "default": "Toutes nos collections"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description (hero)",
      "default": "Explorez les univers Sarah Robe : robes d'été, ensembles légers, accessoires solaires et parfums lumineux."
    },
    {
      "type": "range",
      "id": "max_collections",
      "label": "Nombre max de collections affichées",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "hide_empty",
      "label": "Masquer les collections sans produits",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Afficher le nombre de produits",
      "default": true
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texte du bouton",
      "default": "Voir la sélection →"
    }
  ]
}
{% endschema %}
