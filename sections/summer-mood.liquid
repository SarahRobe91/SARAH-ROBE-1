<!-- ============================================================
   SUMMER MOOD — Section immersive verte
   ============================================================ -->
<section class="sr-summer-mood">
  <!-- Wave top -->
  <svg class="sr-wave-top" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,40 C300,102 620,-16 1000,36 C1220,66 1340,76 1440,38 L1440,0 L0,0 Z" fill="#FBF7F1"/>
  </svg>

  <div class="sr-summer-mood__inner">
    <div class="sr-summer-mood__text">
      <span class="sr-summer-mood__script">{{ section.settings.script | default: "summer mood" }}</span>
      <h2 class="sr-summer-mood__h2">{{ section.settings.heading | default: "Des pièces pensées pour les journées ensoleillées" }}</h2>
      <p class="sr-summer-mood__desc">{{ section.settings.description | default: "Entre élégance légère, matières fluides et parfums délicats, Sarah Robe accompagne vos plus beaux moments d'été." }}</p>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}"
         class="sr-btn sr-btn--primary"
         style="margin-top:30px;display:inline-block">
        {{ section.settings.cta_label | default: "Découvrir l'univers" }}
      </a>
    </div>

    <div class="sr-summer-mood__visual">
      <div class="sr-summer-mood__blob
                  {%- if section.settings.mood_image == blank %} sr-summer-mood__blob--placeholder{%- endif -%}">
        {%- if section.settings.mood_image != blank -%}
          <img src="{{ section.settings.mood_image | image_url: width: 860 }}"
               alt="{{ section.settings.mood_image.alt | escape }}"
               style="width:100%;height:100%;object-fit:cover"
               loading="lazy">
        {%- else -%}
          photo lifestyle organique
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Wave bottom -->
  <svg class="sr-wave-bottom" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,48 C300,-18 620,104 1000,50 C1220,18 1340,8 1440,48 L1440,90 L0,90 Z" fill="#FBF7F1"/>
  </svg>

  <!-- Mobile waves -->
  <style>
  @media (max-width:768px) {
    .sr-summer-mood .sr-wave-top  { height:46px; }
    .sr-summer-mood .sr-wave-bottom { height:46px; }
    .sr-summer-mood .sr-wave-top path  { d:path("M0,30 C110,64 250,-6 390,26 L390,0 L0,0 Z"); }
    .sr-summer-mood .sr-wave-bottom path { d:path("M0,30 C110,-4 250,64 390,32 L390,60 L0,60 Z"); }
  }
  </style>
</section>

{% schema %}
{
  "name": "Summer Mood",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "script",
      "label": "Label cursive",
      "default": "summer mood"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Des pièces pensées pour les journées ensoleillées"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Entre élégance légère, matières fluides et parfums délicats, Sarah Robe accompagne vos plus beaux moments d'été."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Bouton – texte",
      "default": "Découvrir l'univers"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Bouton – lien"
    },
    {
      "type": "image_picker",
      "id": "mood_image",
      "label": "Image lifestyle (organique)"
    }
  ],
  "presets": [
    {
      "name": "Summer Mood"
    }
  ]
}
{% endschema %}
