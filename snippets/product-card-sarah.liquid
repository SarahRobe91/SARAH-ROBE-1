{%- if product != blank -%}

{%- liquid
  assign card_class = card_class | default: 'sr-card'
  assign show_atc = show_atc | default: true

  assign badge_text = ''
  assign badge_class = 'sr-card__badge--rose'

  if product.metafields.custom.badge != blank
    assign badge_text = product.metafields.custom.badge
  elsif product.tags contains 'best-seller'
    assign badge_text = 'Best-seller'
    assign badge_class = 'sr-card__badge--rose'
  elsif product.tags contains 'nouveaute'
    assign badge_text = 'Nouveau'
    assign badge_class = 'sr-card__badge--vert'
  endif

  assign compare_price = product.compare_at_price
  assign current_price = product.price
  assign on_sale = false

  if compare_price > current_price and compare_price > 0
    assign on_sale = true
    if badge_text == ''
      assign discount_pct = compare_price | minus: current_price | times: 100 | divided_by: compare_price | round
      assign badge_text = '-' | append: discount_pct | append: '%'
      assign badge_class = 'sr-card__badge--gold'
    endif
  endif

  assign sold_out = true
  if product.available
    assign sold_out = false
  endif
-%}

<article class="{{ card_class }}">
  <a href="{{ product.url }}" class="sr-card__media" style="display:block">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}"
           alt="{{ product.featured_image.alt | escape | default: product.title }}"
           class="sr-card__img"
           width="{{ product.featured_image.width }}"
           height="{{ product.featured_image.height }}"
           loading="lazy">
    {%- else -%}
      <div class="sr-card__placeholder"
           style="background:repeating-linear-gradient(135deg,#F2DCD6,#F2DCD6 14px,#F8E7E2 14px,#F8E7E2 28px);position:absolute;inset:0">
      </div>
    {%- endif -%}
    {%- if badge_text != '' -%}
      <span class="sr-card__badge {{ badge_class }}">{{ badge_text }}</span>
    {%- endif -%}
  </a>

  <div class="sr-card__footer">
    <a href="{{ product.url }}" class="sr-card__title" style="color:inherit">{{ product.title }}</a>
    <span class="sr-card__price">
      {%- if on_sale -%}
        <span class="sr-card__price--old">{{ compare_price | money }}</span>
      {%- endif -%}
      {{ current_price | money }}
    </span>
  </div>

  {%- if show_atc -%}
    {%- if sold_out -%}
      <button class="sr-card__atc sr-card__atc--disabled" disabled>Bientôt de retour</button>
    {%- else -%}
      <button class="sr-card__atc"
              data-sr-atc="{{ product.selected_or_first_available_variant.id }}"
              data-sr-atc-label="Ajouter au panier">
        Ajouter au panier
      </button>
    {%- endif -%}
  {%- endif -%}
</article>

{%- endif -%}
